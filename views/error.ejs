<% layout('/layout/boilerplate') %>

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <i class="fa-solid fa-triangle-exclamation fa-4x mb-3" style="color: var(--yc-orange);"></i>
        <h1 class="fw-bold">Oops!</h1>
        <h4 class="text-muted mb-3"><%= err.message %></h4>
        <p class="text-muted small font-monospace bg-light p-3 rounded text-start"><%= err.stack %></p>
        <a href="/campgrounds" class="btn btn-yc-primary mt-2 px-4">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to Campgrounds
        </a>
    </div>
</div>
