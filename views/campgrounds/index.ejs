<% layout('/layout/boilerplate') %>

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1><i class="fa-solid fa-compass me-2"></i>Explore Campgrounds</h1>
        <p>Discover <%= campgrounds.length %> amazing campsites across the United States</p>
    </div>
    <% if(currentUser) { %>
    <a href="/campgrounds/new" class="btn btn-light fw-bold px-4">
        <i class="fa-solid fa-plus me-2"></i>Add Campground
    </a>
    <% } else { %>
    <a href="/register" class="btn btn-light fw-bold px-4">
        <i class="fa-solid fa-user-plus me-2"></i>Join to Add
    </a>
    <% } %>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 pb-4">
    <% for (let campground of campgrounds) { %>
    <div class="col">
        <div class="card campground-card h-100">
            <img class="campground-img"
                src="<%= campground.image || 'https://picsum.photos/seed/' + campground._id + '/800/500' %>"
                alt="<%= campground.title %>">
            <div class="card-body">
                <h5 class="card-title fw-bold mb-1"><%= campground.title %></h5>
                <p class="text-muted small mb-2">
                    <i class="fa-solid fa-location-dot me-1" style="color: var(--yc-green);"></i>
                    <%= campground.location %>
                </p>
                <p class="card-text text-muted small" style="line-height:1.5;">
                    <%= campground.description.substring(0, 90) %>...
                </p>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center py-3">
                <span class="badge-price">
                    <i class="fa-solid fa-dollar-sign me-1"></i><%= campground.price %>/night
                </span>
                <a href="/campgrounds/<%= campground._id %>" class="btn btn-sm btn-outline-success fw-bold">
                    View <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
    <% } %>
</div>
